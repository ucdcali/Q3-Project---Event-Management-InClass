<%- include('../partials/header') %>

<h1>Add New College</h1>

<p class="subtitle">
Create a new college entry for the campus event.
</p>

<div class="card">
  <form method="POST" action="/admin/colleges" enctype="multipart/form-data">
    <label>College Name</label>
    <input name="name" required>

    <label>Representative Name</label>
    <input name="repName">

    <label>Representative Email</label>
    <input name="repEmail">

    <label>Representative Phone</label>
    <input name="repPhone">

    <label>Website</label>
    <input name="website" placeholder="https://example.edu">

    <label>Notes</label>
    <textarea name="notes"></textarea>

    <label>College Logo</label>
    <input type="file" name="icon">

    <button class="btn">Create College</button>
  </form>
</div>

<%- include('../partials/footer') %>